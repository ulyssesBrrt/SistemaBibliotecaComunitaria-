         </image>

      </ImageView>
      <TextField fx:id="txtNome" layoutX="509.0" layoutY="190.0" prefHeight="34.0" prefWidth="321.0" style="-fx-background-color: transparent;">
         <font>
            <Font name="Poppins Medium" size="12.0" />
         </font></TextField>
      <TextField fx:id="txtSobrenome" layoutX="509.0" layoutY="251.0" prefHeight="34.0" prefWidth="321.0" style="-fx-background-color: trasnparent;">
