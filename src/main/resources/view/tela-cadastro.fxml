            <Font name="Poppins Medium" size="12.0" />
         </font></TextField>
      <TextField fx:id="txtCpf" layoutX="509.0" layoutY="312.0" prefHeight="34.0" prefWidth="321.0" style="-fx-background-color: trasnparent;" AnchorPane.bottomAnchor="294.0">
