        </ImageView>
      <Button fx:id="btnDashboard" layoutX="315.0" layoutY="14.0" mnemonicParsing="false" onAction="#abrirDashboard" prefHeight="25.0" prefWidth="69.0" style="-fx-background-color: transparent;" />
