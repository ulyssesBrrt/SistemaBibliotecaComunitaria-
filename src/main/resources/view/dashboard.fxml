            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.biblioteca.controller.DashboardController">

    <children>

        <!-- Imagem de fundo -->
        <ImageView fitHeight="640.0" fitWidth="900.0" pickOnBounds="true" preserveRatio="false">

