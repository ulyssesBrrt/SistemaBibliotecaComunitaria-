<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="640.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.biblioteca.controller.AcervoController">

   <ImageView fitHeight="640.0" fitWidth="900.0" pickOnBounds="true" preserveRatio="false">
      <image>
         <Image url="@imagens/ACERVO0.png" />
      </image>
   </ImageView>

   <Button fx:id="btnDashboard" layoutX="320.0" layoutY="14.0" onAction="#abrirDashboard" prefHeight="15.0" prefWidth="60.0" style="-fx-background-color: transparent;" />

   <Button fx:id="btnAcervo" layoutX="399.0" layoutY="14.0" onAction="#abrirAcervo" prefHeight="25.0" prefWidth="51.0" style="-fx-background-color: transparent;" />

   <Button fx:id="btnTrocas" layoutX="469.0" layoutY="14.0" onAction="#abrirTrocas" prefHeight="25.0" prefWidth="51.0" style="-fx-background-color: transparent;" />

   <Button fx:id="btnUsuario" layoutX="534.0" layoutY="14.0" onAction="#abrirUsuario" prefHeight="25.0" prefWidth="51.0" style="-fx-background-color: transparent;" />

   <TextField fx:id="txtPesquisa" layoutX="98.0" layoutY="143.0" prefHeight="46.0" prefWidth="752.0" style="-fx-background-color: transparent;" />

   <Button fx:id="btnCadastrarLivro" layoutX="747.0" layoutY="204.0" onAction="#cadastrarLivros" prefHeight="32.0" prefWidth="105.0" style="-fx-background-color: transparent;" />
   <Label fx:id="lblQuantidadeLivros"
          layoutX="50.0"
          layoutY="208.0"
          text="0 livros encontrados..."
          textFill="#a9a096" />

   <Button fx:id="btnPesquisar" layoutX="68.0" layoutY="154.0" onAction="#pesquisarLivros" prefHeight="25.0" prefWidth="20.0" style="-fx-background-color: transparent;" />
   <ScrollPane fitToWidth="true" layoutX="50.0" layoutY="250.0" prefHeight="350.0" prefWidth="800.0" style="-fx-background-color: transparent;
       -fx-background: transparent;
       -fx-border-color: transparent;">

      <content>
         <FlowPane fx:id="flowLivros"
                   hgap="20.0"
                   prefHeight="348.0"
                   prefWidth="798.0"
                   prefWrapLength="780.0"
                   style="-fx-background-color: transparent;"
                   vgap="20.0" />
      </content>

   </ScrollPane>

</AnchorPane>
